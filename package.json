{
  "name": "stitchable",
  "version": "0.1.0",
  "description": "DOM element based feedback library for browser apps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimsangjunv1/stitchable.git"
  },
  "homepage": "https://github.com/kimsangjunv1/stitchable",
  "bugs": {
    "url": "https://github.com/kimsangjunv1/stitchable/issues"
  },
  "type": "module",
  "sideEffects": [
    "./dist/components/report/ensureReportStyles.js"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./report": {
      "types": "./dist/report/index.d.ts",
      "import": "./dist/report/index.js"
    },
    "./report.css": "./dist/components/report/report.css"
  },
  "scripts": {
    "dev": "vite --config examples/basic/vite.config.ts",
    "build": "node scripts/inline-report-css.mjs && tsc -p tsconfig.json",
    "size:dist": "node scripts/print-dist-size.mjs",
    "example:build": "vite build --config examples/basic/vite.config.ts",
    "size:example": "npm run example:build",
    "typecheck": "node scripts/inline-report-css.mjs && tsc -p tsconfig.json --noEmit && tsc -p examples/basic/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run typecheck && npm run test",
    "example": "npm run dev"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "^5.4.19",
    "vitest": "^4.1.7"
  }
}
