{
    "name": "@fivepixels-js/react",
    "version": "0.2.0",
    "description": "React library for DOM element feedback markers on staging, QA, and internal tool UIs",
    "license": "MIT",
    "keywords": [
        "react",
        "feedback",
        "qa",
        "staging",
        "dom",
        "markers",
        "review",
        "shadow-dom",
        "ui",
        "fivepixels",
        "visual-feedback",
        "github-issues"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/kimsangjunv1/fivepixels.git"
    },
    "homepage": "https://library.codi-agit.com/fivepixels/guide",
    "bugs": {
        "url": "https://github.com/kimsangjunv1/fivepixels/issues"
    },
    "type": "module",
    "engines": {
        "node": ">=22.11.0"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./report": {
            "types": "./dist/components/report/index.d.ts",
            "import": "./dist/components/report/index.js"
        }
    },
    "scripts": {
        "dev": "vite --config examples/basic/vite.config.ts",
        "build": "node scripts/clean-dist.mjs && node scripts/build-report-styles.mjs && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
        "size:dist": "node scripts/print-dist-size.mjs",
        "size:bundle": "npm run build && node scripts/measure-bundle-size.mjs",
        "example:build": "vite build --config examples/basic/vite.config.ts",
        "size:example": "npm run example:build",
        "typecheck": "node scripts/build-report-styles.mjs && tsc -p tsconfig.json --noEmit && tsc -p examples/basic/tsconfig.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "check:utils": "node scripts/check-no-flat-utils.mjs",
        "lint": "npm run check:utils && npm run typecheck && npm run test",
        "example": "npm run dev"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.5.0",
        "cssnano": "^8.0.1",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.15",
        "react-router-dom": "^7.16.0",
        "tailwindcss": "^4.3.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.0.0",
        "vite": "^6.3.5",
        "vitest": "^4.1.7",
        "zustand": "^5.0.14"
    }
}
